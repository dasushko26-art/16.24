import sys
import subprocess

# Автоматичне встановлення бібліотеки, якщо вона не знайдена
try:
    import cv2
except ImportError:
    print("Бібліотека cv2 не знайдена. Встановлюю...")
    subprocess.check_call([sys.executable, "-m", "pip", "install", "opencv-python"])
    import cv2

print("Бібліотека успішно підключена!")

# Перевірка наявності файлу (переконайтеся, що input.jpg лежить у папці pythonProject)
if not cv2.os.path.exists('input.jpg'):
    print("Помилка: Файл 'input.jpg' не знайдено в папці проекту.")
else:
    img = cv2.imread('input.jpg')

    face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + 'haarcascade_frontalface_default.xml')
    faces = face_cascade.detectMultiScale(img, 1.1, 4)

    for (x, y, w, h) in faces:
        cv2.rectangle(img, (x, y), (x+w, y+h), (0, 255, 0), 2)

    cv2.imshow('Result', img)
    cv2.waitKey(0)
    cv2.destroyAllWindows()
